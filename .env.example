# ─────────────────────────────────────────────────────────────
# Site-80 "JACOBY" — environment configuration
# Copy this file to `.env` and fill in real values.
# ─────────────────────────────────────────────────────────────

# PostgreSQL connection string
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/site80?schema=public"

# NextAuth — generate a strong secret: `openssl rand -base64 32`
NEXTAUTH_SECRET="replace-me-with-a-long-random-string"
NEXTAUTH_URL="http://localhost:3000"

# Toggle security features in development
NODE_ENV="development"

# Optional: enforce HTTPS-only secure cookies (set true in production)
SECURE_COOKIES="false"
